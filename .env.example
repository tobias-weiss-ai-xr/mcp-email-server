# =============================================================================
# MCP Email Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Environment variables take precedence over TOML configuration.
# =============================================================================

# --- General ---
# MCP_EMAIL_SERVER_CONFIG_PATH=~/.config/zerolib/mcp_email_server/config.toml
# MCP_EMAIL_SERVER_LOG_LEVEL=INFO
# MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD=false

# --- Email Account ---
MCP_EMAIL_SERVER_ACCOUNT_NAME=default
MCP_EMAIL_SERVER_FULL_NAME=John Doe
MCP_EMAIL_SERVER_EMAIL_ADDRESS=john@example.com
MCP_EMAIL_SERVER_USER_NAME=john@example.com
MCP_EMAIL_SERVER_PASSWORD=your_password_here

# --- IMAP (Incoming) ---
MCP_EMAIL_SERVER_IMAP_HOST=imap.example.com
MCP_EMAIL_SERVER_IMAP_PORT=993
MCP_EMAIL_SERVER_IMAP_SSL=true
MCP_EMAIL_SERVER_IMAP_VERIFY_SSL=true
# MCP_EMAIL_SERVER_IMAP_USER_NAME=   # Defaults to MCP_EMAIL_SERVER_USER_NAME
# MCP_EMAIL_SERVER_IMAP_PASSWORD=    # Defaults to MCP_EMAIL_SERVER_PASSWORD

# --- SMTP (Outgoing) ---
MCP_EMAIL_SERVER_SMTP_HOST=smtp.example.com
MCP_EMAIL_SERVER_SMTP_PORT=465
MCP_EMAIL_SERVER_SMTP_SSL=true
MCP_EMAIL_SERVER_SMTP_START_SSL=false
MCP_EMAIL_SERVER_SMTP_VERIFY_SSL=true
# MCP_EMAIL_SERVER_SMTP_USER_NAME=   # Defaults to MCP_EMAIL_SERVER_USER_NAME
# MCP_EMAIL_SERVER_SMTP_PASSWORD=    # Defaults to MCP_EMAIL_SERVER_PASSWORD

# --- Sent Folder ---
# MCP_EMAIL_SERVER_SAVE_TO_SENT=true
# MCP_EMAIL_SERVER_SENT_FOLDER_NAME=

# --- Cover Letter Template (for create_cover_letter_draft tool) ---
# MCP_EMAIL_SERVER_TEMPLATE_BASE=/path/to/latex/templates
